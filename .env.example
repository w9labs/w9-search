OPENROUTER_API_KEY=your_openrouter_api_key_here
# Public app URL used for OAuth callbacks in production
APP_BASE_URL=https://search.w9.nu
# Optional LLM Providers (The system automagically detects available models)
GROQ_API_KEY=your_groq_api_key_here
CEREBRAS_API_KEY=your_cerebras_api_key_here
COHERE_API_KEY=your_cohere_api_key_here
POLLINATIONS_API_KEY=your_pollinations_api_key_here

# Optional Search Providers (Default: hosted SearXNG)
SEARXNG_BASE_URL=https://searxng.w9.nu
# Traefik router rule (only needed if you run the local-search profile)
# SEARXNG_TRAEFIK_RULE=Host(`search.example.com`) || Host(`search2.example.com`)
# Secret key for SearXNG (Required only if using the local-search profile)
SEARXNG_SECRET=generate_a_strong_random_key_here
BRAVE_API_KEY=your_brave_search_api_key
TAVILY_API_KEY=your_tavily_api_key

DATABASE_URL=sqlite:w9_search.db

# Comma-separated list of allowed OpenRouter model IDs (first is default)
# Note: Models from other providers are fetched automatically
OPENROUTER_MODELS=tngtech/deepseek-r1t2-chimera:free,arcee-ai/trinity-large-preview:free
